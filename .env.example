# ----- Server -----
# Optional. Default: 8080
SERVER_PORT=8080

# Optional. Default: dev. Giá trị: dev | prod
SPRING_PROFILES_ACTIVE=dev


# ----- Postgres -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=goodminton
POSTGRES_USERNAME=admin
POSTGRES_PASSWORD=change-me


# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379


# ----- JWT -----
JWT_SECRET=replace-with-a-strong-base64-secret-min-64-chars
JWT_ACCESS_EXP=600000
JWT_REFRESH_EXP=604800000


# ----- Cloudinary -----
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER_PREFIX=goodminton


# ----- VNPay -----
# Sandbox: https://sandbox.vnpayment.vn — đăng ký merchant để lấy TmnCode + HashSecret
VNP_TMN_CODE=your-vnpay-tmn-code
VNP_HASH_SECRET=your-vnpay-hash-secret
# Optional. Default: sandbox URL
VNP_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# URL backend public (VNPay redirect browser tới đây). Phải là URL đầy đủ.
VNP_RETURN_URL=https://your-domain.com/api/vnpay/callback
# URL frontend mà /api/vnpay/callback redirect tới sau khi verify chữ ký
VNP_FRONTEND_RETURN_URL=https://your-frontend.com/payment/result


# ----- Mail (SMTP Gmail) -----
# Host hardcode trong application.yaml: smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# App Password 16 ký tự (https://myaccount.google.com/apppasswords)
MAIL_PASSWORD=xxxx xxxx xxxx xxxx


# ----- Frontend -----
FRONTEND_URL=http://localhost:3000


# ----- Super admin (V3 migration seed) -----
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PHONE=0123456789
ADMIN_PASSWORD=ChangeMe@123
